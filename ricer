#!/usr/bin/env bash

# /*
#  * 󰏘 LUTGEN RICER
#  * Author: Ezequiel (Zeke)
#  *
#  * Interactive script for wallpaper ricing.
#  * Flow managed via state machine to allow backtracking (ESC).
#  */

# //
# // Color variables for logging
# //

C_BLUE="\e[1;34m"; C_GREEN="\e[1;32m"; C_RED="\e[1;31m"; C_YELLOW="\e[1;33m"; C_CYAN="\e[1;36m"; C_RESET="\e[0m"

# //
# // Base Configuration
# //

REPO_URL="https://github.com/ezequielgk/noctalia-colorschemes"
LUTGEN_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/lutgen"
SYNC_MARKER="$LUTGEN_DIR/.synced"

# // Supported image extensions (webp included)
IMG_PATTERN=(-iname "*.jpg" -o -iname "*.jpeg" -o -iname "*.png" -o -iname "*.webp")

# // Global fzf styling for UI consistency
export FZF_DEFAULT_OPTS="--layout=reverse --border=rounded --info=inline --prompt='❯ '"

# // Ensure config directory exists before anything else
mkdir -p "$LUTGEN_DIR"

# /*
#  * PREVIEW GENERATORS (TEMP SCRIPTS)
#  * Using temporary files for fzf previews.
#  * Trap handles cleanup when the script exits or is interrupted.
#  */

PREVIEW_SCRIPT=$(mktemp)
LUTGEN_PREVIEW_SCRIPT=$(mktemp)
trap 'rm -f "$PREVIEW_SCRIPT" "$LUTGEN_PREVIEW_SCRIPT"' EXIT SIGINT SIGTERM

# //
# // 1. Preview for local palettes (Generates ANSI TrueColor blocks)
# //

cat << 'EOF' > "$PREVIEW_SCRIPT"
#!/usr/bin/env bash
lutgen_dir="$1"
shift # // Drop the first argument to iterate cleanly over the rest

for item in "$@"; do
    files=()
    # // Quick check: is it a direct file (Settings) or a base name (Selector)?
    if [[ -f "$lutgen_dir/$item" ]]; then
        files=("$item")
    else
        files=("$item-dark" "$item-light")
    fi

    for file in "${files[@]}"; do
        # // Skip silently if the variant doesn't exist
        [[ ! -f "$lutgen_dir/$file" ]] && continue
        
        # // Read hex values and build ANSI blocks
        read -r -a colors < "$lutgen_dir/$file"
        [[ ${#colors[@]} -eq 0 ]] && continue

        echo -e "    Palette: $file\n"

        for _ in 1 2 3; do
            echo -n "  "
            for hex in "${colors[@]}"; do
                hex="${hex//\#/}" # // Sanitize '#' just in case
                if [[ ${#hex} -eq 6 ]]; then
                    # // Bash black magic to convert HEX to native RGB
                    r=$((16#${hex:0:2}))
                    g=$((16#${hex:2:2}))
                    b=$((16#${hex:4:2}))
                    printf "\e[48;2;%d;%d;%dm        \e[0m" "$r" "$g" "$b"
                fi
            done
            echo ""
        done
        echo -e "\n"
    done
done
EOF
chmod +x "$PREVIEW_SCRIPT"

# //
# // 2. Preview for Lutgen built-in palettes (Fast/Lightweight version)
# //

cat << 'EOF' > "$LUTGEN_PREVIEW_SCRIPT"
#!/usr/bin/env bash
palette="$1"

echo -e "\n  󰏘  Built-in Palette: $palette\n"
echo -e "  [i] Color preview not available."
echo -e "      Built-in palettes are compiled"
echo -e "      inside the lutgen binary."
echo -e "\n  Use lutgen-studio for previews."
EOF
chmod +x "$LUTGEN_PREVIEW_SCRIPT"


# /*
#  * CORE FUNCTIONS
#  */

# // Sanity check: prevent headaches by verifying dependencies upfront
check_deps() {
    for cmd in lutgen jq curl tar fzf chafa; do
        if ! command -v "$cmd" &> /dev/null; then
            echo -e "${C_RED}[ERROR] Missing dependency: '$cmd'.${C_RESET}"
            exit 1
        fi
    done
}

# // Sync Noctalia repo. Uses a cache flag to avoid spamming the GitHub API

sync_palettes() {
    local force_sync="$1"
    if [[ -f "$SYNC_MARKER" && "$force_sync" != "true" ]]; then
        return # // Already cached, exit early
    fi

    echo -e "${C_BLUE}[*] Syncing palettes from GitHub...${C_RESET}"
    local tmp_dir=$(mktemp -d)

    # // Download tarball and extract on-the-fly
    if curl -sL "${REPO_URL%/}/archive/refs/heads/main.tar.gz" | tar -xz -C "$tmp_dir" --strip=1 &> /dev/null; then
        find "$tmp_dir" -name "*.json" | while read -r file; do
            local base_name=$(basename "$(dirname "$file")")
            [[ "$base_name" == *"$tmp_dir"* ]] && base_name="${file%.json}"

            # // Parse JSON with jq and extract only the required hex values
            for variant in dark light; do
                local colors=$(jq -r ".[ \"$variant\" ] | [.mSurface, .mOnSurface, .mPrimary, .mSecondary, .mTertiary] | map(strings | sub(\"^#\"; \"\") | ascii_downcase) | unique | join(\" \")" "$file" 2>/dev/null)
                if [[ -n "$colors" ]]; then
                    echo "$colors" > "$LUTGEN_DIR/${base_name,,}-${variant}"
                fi
            done
        done
        touch "$SYNC_MARKER"
        echo -e "${C_GREEN}[OK] Palettes synchronized.${C_RESET}"
        sleep 1
    else
        echo -e "${C_RED}[ERROR] Download failed.${C_RESET}"
        sleep 2
    fi
    rm -rf "$tmp_dir"
}

# // Regenerate lutgen config file based on our local text files

generate_toml() {
    local toml_file="$LUTGEN_DIR/palettes.toml"
    > "$toml_file" # // Truncate file

    for file in "$LUTGEN_DIR/"*; do
        if [ -f "$file" ] && [[ "$file" != *.toml ]] && [[ "$file" != *.synced ]]; then
            local name=$(basename "$file")
            local colors_toml=$(awk '{ for(i=1;i<=NF;i++) printf "\"%s\"%s", ($i ~ /^#/ ? $i : "#"$i), (i==NF ? "" : ", ") }' "$file")
            echo "[\"${name,,}\"]" >> "$toml_file"
            echo "colors = [$colors_toml]" >> "$toml_file"
            echo "" >> "$toml_file"
        fi
    done
}

# // Core processing logic
# // Returns: 0=Processed, 1=Skipped (cache hit), 2=Lutgen error

process_image() {
    local src="$1" dest="$2" theme="$3"
    
    # // If destination is newer than source, skip processing to save time
    if [[ -f "$dest" && ! "$src" -nt "$dest" ]]; then
        return 1
    fi
    
    mkdir -p "$(dirname "$dest")"
    cp "$src" "$dest"
    
    local tmp="${dest}_lutgen_tmp.${dest##*.}"
    if lutgen apply -p "${theme,,}" "$dest" -o "$tmp" &>/dev/null; then
        mv "$tmp" "$dest"
        return 0
    else
        rm -f "$tmp"
        return 2
    fi
}

# // Local palette editor
menu_settings() {
    mapfile -t schemes < <(find "$LUTGEN_DIR" -maxdepth 1 -type f ! -name "*.toml" ! -name ".synced" -exec basename {} \; | sort)
    
    local selected=$(printf "%s\n" "${schemes[@]}" | fzf \
        --prompt="  Edit Local Palette ❯ " \
        --header="[ENTER]: Edit  |  [ESC]: Back to menu" \
        --preview "'$PREVIEW_SCRIPT' '$LUTGEN_DIR' {}" \
        --preview-window=right:50%:border-left)

    if [[ -n "$selected" ]]; then
        ${EDITOR:-nano} "$LUTGEN_DIR/$selected"
        generate_toml
        echo -e "${C_GREEN}[OK] Palette updated.${C_RESET}"
        sleep 1
    fi
}


# /*
#  * MAIN WORKFLOW (STATE MACHINE)
#  */

check_deps
sync_palettes "false"

STATE="MAIN"

# // Main application loop
while true; do
    case "$STATE" in
        "MAIN")
            # // Binding q:abort here allows quick exit without breaking text search in other menus
            MAIN_CHOICE=$(printf "1. Process full folder\n2. Individual selection (fzf)\n3. Force palette update\n4. Settings (View/Edit local palettes)\nq. Exit" | \
                fzf --prompt="[ 󰏘 LUTGEN RICER ] ❯ " \
                    --header="[q / ESC]: Exit" \
                    --bind="q:abort")
            
            # // If ESC or 'q' is pressed, exit gracefully
            if [[ -z "$MAIN_CHOICE" ]]; then
                echo -e "${C_YELLOW}Exiting Ricer...${C_RESET}"
                exit 0
            fi

            case "$MAIN_CHOICE" in
                1*) SOURCE_MODE="Full folder"; STATE="SOURCE" ;;
                2*) SOURCE_MODE="Individual"; STATE="SOURCE" ;;
                3*) sync_palettes "true"; STATE="MAIN" ;;
                4*) menu_settings; STATE="MAIN" ;;
                q*) echo -e "${C_YELLOW}Exiting...${C_RESET}"; exit 0 ;;
            esac
            ;;

        "SOURCE")
            if [[ "$SOURCE_MODE" == "Full folder" ]]; then
                mapfile -t folders < <(find . -maxdepth 1 -type d ! -name "." ! -name ".*" | sed 's|^\./||' | sort)
                SOURCE_DIR=$(printf "%s\n" "${folders[@]}" | fzf --prompt="  Source folder ❯ " --header="[ESC]: Back")
                
                # // Handle backtracking
                [[ -z "$SOURCE_DIR" ]] && { STATE="MAIN"; continue; }
            else
                mapfile -t SELECTED_FILES < <(find . -type f \( "${IMG_PATTERN[@]}" \) | sed 's|^\./||' | sort | \
                    fzf --multi \
                        --prompt="  Select images ❯ " \
                        --header="[TAB]: Toggle | [CTRL-A]: Select All | [ESC]: Back" \
                        --bind="ctrl-a:select-all,ctrl-d:deselect-all,ctrl-t:toggle-all" \
                        --preview 'chafa -f sixel -s "${FZF_PREVIEW_COLUMNS}x${FZF_PREVIEW_LINES}" {}' \
                        --preview-window=right:55%:border-left)
                
                [[ ${#SELECTED_FILES[@]} -eq 0 ]] && { STATE="MAIN"; continue; }
                SOURCE_DIR="Individual"
            fi
            STATE="PALETTE_TYPE"
            ;;

        "PALETTE_TYPE")
            PALETTE_TYPE=$(printf "1. Custom (Local Repository)\n2. Built-in (Lutgen Native)" | fzf --prompt="  Palette Source ❯ " --header="[ESC]: Back")
            [[ -z "$PALETTE_TYPE" ]] && { STATE="SOURCE"; continue; }
            STATE="PALETTE_SEL"
            ;;

        "PALETTE_SEL")
            if [[ "$PALETTE_TYPE" == 1* ]]; then
                mapfile -t schemes < <(find "$LUTGEN_DIR" -maxdepth 1 -type f ! -name "*.toml" ! -name ".synced" -exec basename {} \; | sed -E 's/-(dark|light)$//' | sort -u)
                
                SELECTED_PALETTE=$(printf "%s\n" "${schemes[@]}" | fzf \
                    --prompt="  Select Custom Palette ❯ " \
                    --header="[ESC]: Back" \
                    --preview "'$PREVIEW_SCRIPT' '$LUTGEN_DIR' {}" \
                    --preview-window=right:50%:border-left)
                
                [[ -z "$SELECTED_PALETTE" ]] && { STATE="PALETTE_TYPE"; continue; }
                
                generate_toml
                THEME_DARK="${SELECTED_PALETTE}-dark"
                THEME_LIGHT="${SELECTED_PALETTE}-light"
                DEST_BASE="$SELECTED_PALETTE"
            else
                mapfile -t lutgen_schemes < <(lutgen palette names | sort)
                
                THEME_DARK=$(printf "%s\n" "${lutgen_schemes[@]}" | fzf \
                    --prompt="󰏘  Select Built-in Palette ❯ " \
                    --header="[ESC]: Back" \
                    --preview "'$LUTGEN_PREVIEW_SCRIPT' {}" \
                    --preview-window=right:50%:border-left)
                
                [[ -z "$THEME_DARK" ]] && { STATE="PALETTE_TYPE"; continue; }
                
                THEME_LIGHT="$THEME_DARK"
                DEST_BASE="$THEME_DARK"
            fi
            STATE="VARIANT"
            ;;

        "VARIANT")
            VAR_CHOICE=$(printf "Dark\nLight\nBoth" | fzf --prompt="  Variant to generate ❯ " --header="[ESC]: Back")
            [[ -z "$VAR_CHOICE" ]] && { STATE="PALETTE_SEL"; continue; }

            case "$VAR_CHOICE" in
                Dark) VARIANT_LIST=("dark") ;;
                Light) VARIANT_LIST=("light") ;;
                Both) VARIANT_LIST=("dark" "light") ;;
            esac
            STATE="PROCESS"
            ;;

        "PROCESS")
            count_ok=0; count_skip=0; count_err=0

            for var in "${VARIANT_LIST[@]}"; do
                current_theme=$([[ "$var" == "dark" ]] && echo "$THEME_DARK" || echo "$THEME_LIGHT")
                DEST_FINAL="$DEST_BASE/$SOURCE_DIR/$var"
                
                mkdir -p "$DEST_FINAL"
                echo -e "\n${C_BLUE}[*] Generating variant '$var' in '$DEST_FINAL'...${C_RESET}"

                if [[ "$SOURCE_MODE" == "Full folder" ]]; then
                    # // Batch processing using find (safer than ls for weird filenames)
                    while IFS= read -r img; do
                        rel="${img#"$SOURCE_DIR"/}"
                        dest="$DEST_FINAL/$rel"
                        process_image "$img" "$dest" "$current_theme"
                        case $? in 0) ((count_ok++));; 1) ((count_skip++));; *) ((count_err++));; esac
                    done < <(find "$SOURCE_DIR" -type f \( "${IMG_PATTERN[@]}" \))
                else
                    # // Process manual fzf selection
                    for img in "${SELECTED_FILES[@]}"; do
                        dest="$DEST_FINAL/$(basename "$img")"
                        process_image "$img" "$dest" "$current_theme"
                        case $? in 0) ((count_ok++));; 1) ((count_skip++));; *) ((count_err++));; esac
                    done
                fi
            done

            # // Final summary
            echo -e "\n${C_GREEN}[OK] Process completed successfully.${C_RESET}"
            echo -e "${C_CYAN}    Generated: $count_ok  |  Skipped (Cache): $count_skip  |  Errors: $count_err${C_RESET}\n"
            
            # // Clean exit after processing is done
            exit 0
            ;;
    esac
done
